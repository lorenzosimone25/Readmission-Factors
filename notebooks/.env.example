# Copy to notebooks/.env (never commit .env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Ollama Cloud (section labeling — optional LLM with regex fallback)
OLLAMA_API_KEY=your-ollama-cloud-api-key
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b

# Optional: faster model for single-case pilot
# PILOT_MODEL=llama3.2

# Optional cohort setup overrides
# PARQUET_PATH=src/data/readmit_30d.parquet
# CASES_PER_CLINICIAN=30
# INTERSECTION_SIZE=10
# RANDOM_SEED=42
# NOTE_LENGTH_MIN_PERCENTILE=30
# NOTE_LENGTH_MAX_PERCENTILE=90
# MIN_COMBINED_NOTE_CHARS=400
# POSTDAY_BIN_WIDTH=5
# REBUILD_INTERSECTION=true
# RESET_DB=false
# CONFIRM_RESET=

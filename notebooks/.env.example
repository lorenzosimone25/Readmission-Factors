# Copy to notebooks/.env (never commit .env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Ollama Cloud (section labeling — optional LLM with regex fallback)
OLLAMA_API_KEY=your-ollama-cloud-api-key
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b

# Optional: faster model for single-case pilot
# PILOT_MODEL=llama3.2

# Batch flags
# DRY_RUN=true
# USE_LLM=true
